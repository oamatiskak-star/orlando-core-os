{
  "name": "@orlando/ai-worker-node",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Distributed worker process that pulls ai_tasks from Supabase and executes them via the AI router or local handlers.",
  "main": "dist/worker.js",
  "scripts": {
    "dev": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/worker.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "pino": "^9.12.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.21",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
