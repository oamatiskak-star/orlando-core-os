{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/.next",
  "installCommand": "cd frontend && npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/youtube/cron/refresh-tokens",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/youtube/cron/sync-stats",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/youtube/cron/snapshot-daily-stats",
      "schedule": "55 23 * * *"
    },
    {
      "path": "/api/youtube/cron/run-pipeline",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/youtube/cron/sync-video-analytics",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/youtube/cron/viral-scan",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/youtube/cron/audio-scan",
      "schedule": "15 */4 * * *"
    },
    {
      "path": "/api/youtube/cron/trend-scan",
      "schedule": "30 */4 * * *"
    },
    {
      "path": "/api/youtube/cron/content-factory",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/youtube/cron/renderer-dispatch",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/youtube/cron/renderer-poll",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/youtube/cron/atlas-upload",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/executive-layer/cron/decision-engine",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/executive-layer/cron/alert-engine",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/executive-layer/cron/autonomous-scaling",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/youtube/cron/factory-feeder",
      "schedule": "20 */4 * * *"
    },
    {
      "path": "/api/acquisition/cron/deal-scan",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/acquisition/cron/permit-scan",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/acquisition/cron/offmarket-scan",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/acquisition/cron/director-briefing",
      "schedule": "30 7 * * *"
    }
  ]
}
