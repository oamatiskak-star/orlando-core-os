{
  "name": "@orlando-core-os/hermes",
  "version": "0.1.0",
  "private": true,
  "description": "Hermes — additieve orchestration, memory en watchdog laag voor Orlando Core OS.",
  "type": "module",
  "engines": {
    "node": ">=22.10.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint 'src/**/*.ts'",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "pino": "^9.4.0",
    "undici": "^6.19.8",
    "xstate": "^5.18.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "eslint": "^9.10.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
