# Supabase (zelfde als je dashboard)
SUPABASE_URL=https://shaunumewswpxhmgbtvv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Ollama (lokaal draaiend)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# LM Studio (lokaal draaiend, OpenAI-compatible)
LM_STUDIO_URL=http://localhost:1234
LM_STUDIO_MODEL=default
# Gebruik LM Studio als primaire AI (true), anders Ollama
USE_LM_STUDIO=true

# Video output map (lokaal)
VIDEO_OUTPUT_DIR=/tmp/orlando-videos

# Poll interval in seconden
POLL_INTERVAL_SECONDS=30

# ── CF2 shadow-run (host readiness) ───────────────────────────────────────────
# Alias-URLs (cf2:shadow leest BASE_URL met fallback op bovenstaande URL)
OLLAMA_BASE_URL=http://localhost:11434
LM_STUDIO_BASE_URL=http://localhost:1234

# Visual-bron (verplicht voor render; gratis key op pexels.com/api). GEEN echte secret committen.
PEXELS_API_KEY=
# Royalty-free muziekbron (bucket/pad). Leeg = music-gate blokkeert.
MUSIC_CATALOG=
# Caption-font voor render (bestaat-check). macOS-voorbeeld:
CAPTION_FONT=/System/Library/Fonts/Supplemental/Arial.ttf
# TTS-provider: edge_tts (gratis lokaal, aanbevolen) | piper | espeak | local_xtts | openai_tts | elevenlabs
TTS_PROVIDER=edge_tts

# ── CF2 producer gating (NIET aanpassen voor shadow) ──────────────────────────
# prepared = valideert alleen (geen call). live = produceert lokaal via shadow (geen upload).
CF2_PRODUCER_MODE=prepared
# 0 = geen upload/publicatie. cf2:shadow stopt HARD als dit 1 staat.
CF2_PUBLISH=0
# 0 = producer draait niet vanzelf. Shadow-run zet dit expliciet aan de CLI, niet hier.
CF2_PRODUCER_RUN=0
