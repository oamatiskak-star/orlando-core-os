  subgraph HERMES["Hermes (nieuw — additief)"]
    direction TB
    H_CORE["services/hermes/<br/>core + memory"]
    H_SCHEMA[("hermes-schema<br/>migratie 104:<br/>escalations, recipients,<br/>whatsapp_inbox")]
    H_WA_AGENT["subagent #16<br/>whatsapp-bridge"]
    H_EXEC_SUP["subagent #4<br/>Executor Supervisor"]
    H_WORKFLOW_REPAIR["subagent #5<br/>Workflow Repair"]
    H_WHATSAPP_API(["Meta WhatsApp<br/>Cloud API"])
    H_WEBHOOK["/api/hermes/whatsapp/webhook<br/>(HMAC verify)"]
    H_DASHBOARD["/dashboard/hermes<br/>(nieuwe route)"]
    H_CHANNEL([("Realtime channel<br/>hermes:events")])
  end

  %% ==================== EDGES: BESTAANDE FLOW ====================
  AO_DAEMON --> YT_QUEUE
  YT_QUEUE --> AO_PROD
  AO_PROD --> AO_WORKER

  PGCRON_DISP --> LOCAL_AGENT
  PGCRON_HEALTH --> WD_INFRA

  WD_LOCAL --> TG_LW
  WD_YT --> TG_YE
  WD_INFRA --> EXEC_ALERTS
  WD_YT --> EXEC_ALERTS

  EXEC_ALERTS --> TRG094
  TRG094 -->|low / medium| TG_API
  TRG094 -->|high / critical| AUTOPILOT
  AUTOPILOT --> RELAY_API
  RELAY_API --> TG_API
  RELAY_API --> AUDIT

  TG_LW --> TG_API
  TG_WE --> TG_API
  TG_CA --> TG_API
  TG_YE --> TG_API

  EXEC_ALERTS -.bevat company_id.-> COMPANIES

  %% ==================== EDGES: HERMES OBSERVER (dashed) ====================
  AO_DAEMON -.observe.-> H_EXEC_SUP
  YT_QUEUE -.observe.-> H_EXEC_SUP
  WD_INFRA -.observe.-> H_WORKFLOW_REPAIR
  EXEC_ALERTS -.observe.-> H_WA_AGENT
  AUTOPILOT -.observe.-> H_WORKFLOW_REPAIR
  COMPANIES -.lookup os_label.-> H_WA_AGENT

  %% ==================== EDGES: HERMES AUGMENT (thick) ====================
  H_WA_AGENT ==>|na watchdog faal-recovery + dedup| H_SCHEMA
  H_SCHEMA ==>|hermes.escalations.status=pending| H_CORE
  H_CORE ==>|render incident card| H_WHATSAPP_API
  H_WHATSAPP_API ==>|reply webhook| H_WEBHOOK
  H_WEBHOOK ==>|action dispatch| H_CORE
  H_CORE ==>|dispatch quick_fix / full_fix / cancel| H_EXEC_SUP
  H_CORE ==>|dispatch quick_fix / full_fix / cancel| H_WORKFLOW_REPAIR
  H_CORE -->|publish| H_CHANNEL
  H_CHANNEL --> H_DASHBOARD
  H_SCHEMA --> H_DASHBOARD

