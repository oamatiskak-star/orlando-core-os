NODE_ENV=development
PORT=3008
LOG_LEVEL=info

# Supabase (orlando-core-os project: shaunumewswpxhmgbtvv)
SUPABASE_URL=https://shaunumewswpxhmgbtvv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket (must be created in Supabase dashboard, private, service_role only)
SUPABASE_STORAGE_BUCKET=checkout-audit-artifacts

# Anthropic — Opus for analysis, Sonnet for batched
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_PRIMARY=claude-opus-4-7
ANTHROPIC_MODEL_BATCH=claude-sonnet-4-6

# Stripe restricted key — READ-ONLY permissions only on test-mode account
# Permissions needed: Read on Customer, Checkout Session, Subscription, Invoice, Event
STRIPE_RESTRICTED_KEY_TEST=

# Aquier target
AQUIER_BASE_URL=https://aquier.com

# Telegram alerts (groep YT_Agent_OS_Bot / chat 7583931210)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=7583931210

# Audit policy
CHECKOUT_AUDITOR_MAX_SCENARIOS_PER_RUN=20
BROWSER_CONCURRENCY=3
SCENARIO_TIMEOUT_MS=180000
WEBHOOK_WAIT_MAX_MS=60000
AUDIT_RETENTION_DAYS=14

# Auth — POST endpoints require this in Authorization header
RUN_TRIGGER_SECRET=

# Cron timezone
AGENT_TIMEZONE=Europe/Amsterdam
