{
  "name": "@orlando/checkout-auditor",
  "version": "1.0.0",
  "description": "Orlando Core OS — Aquier Checkout Auditor (Playwright + Stripe observer + Claude AI analyse)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/specs','dist/specs',{recursive:true})\"",
    "start": "node dist/index.js",
    "dev": "ts-node --transpile-only src/index.ts",
    "dev:watch": "nodemon --exec ts-node --transpile-only src/index.ts",
    "test": "ts-node --transpile-only tests/run-tests.ts",
    "cli:discover": "ts-node --transpile-only src/cli/run-once.ts discover",
    "cli:scenario": "ts-node --transpile-only src/cli/run-once.ts scenario",
    "cli:analyze": "ts-node --transpile-only src/cli/run-once.ts analyze",
    "cli:audit": "ts-node --transpile-only src/cli/run-once.ts audit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-cron": "^3.0.3",
    "pino": "^9.5.0",
    "playwright": "^1.49.0",
    "stripe": "^17.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "nodemon": "^3.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
