NODE_ENV=production

# Supabase
SUPABASE_URL=https://pmovazftwoxjopqkuuhp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Redis
REDIS_URL=redis://localhost:6379

# YouTube OAuth
YOUTUBE_OAUTH_CLIENT_ID=your_client_id
YOUTUBE_OAUTH_CLIENT_SECRET=your_client_secret
YOUTUBE_OAUTH_REDIRECT_URI=https://dashboard.strkbeheer.nl/api/youtube/oauth/callback

# Worker settings
UPLOAD_WORKER_CONCURRENCY=2
VERIFICATION_INTERVAL_MS=30000
MAX_UPLOAD_RETRIES=5
FFMPEG_THREADS=2

# Browser verification
PLAYWRIGHT_HEADLESS=true
BROWSER_TIMEOUT_MS=30000

# Logging
LOG_LEVEL=info
LOG_TO_FILE=true

# Notifications
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
