# Growth Command — environment
# Supabase (orlando-core-os project: shaunumewswpxhmgbtvv)
SUPABASE_URL=https://shaunumewswpxhmgbtvv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Would Buy Runner). Without this key the runner uses a deterministic
# fallback and reports "needs API key" instead of crashing.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Optional: write daily launch reports to this dir (local, not DB)
GROWTH_COMMAND_REPORT_DIR=./reports

# First €10K sprint target (EUR)
FIRST_SPRINT_TARGET_EUR=10000
